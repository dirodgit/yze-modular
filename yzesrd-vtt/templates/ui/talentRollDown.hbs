<div class='item-desc'>
    <b>{{localize 'yzesrdvtt.prerequisite'}}</b>: {{system.prerequisite}} <br>
    <b>{{localize 'yzesrdvtt.description'}}:</b>
    {{system.description}} <br>
    {{#if system.hasBonus}}
    <b>{{localize 'yzesrdvtt.bonusType'}}:</b> {{localize system.bonusType}} <br>
    <b>{{localize 'yzesrdvtt.bonus'}}:</b> {{system.bonus}} <br>
    {{#if (eq system.bonusType 'yzesrdvtt.skill')}}
    <b>{{localize 'yzesrdvtt.skill'}}:</b> {{localize system.skill}} <br>
    {{/if}}
    {{/if}}
</div>
