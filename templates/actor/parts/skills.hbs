<div class="skills-section">
  <div class="section-header">
    <h3>Perícias</h3>
    <button type="button" data-action="createItem" data-type="skill"><i class="fas fa-plus"></i></button>
  </div>
  <div class="skill-list">
    {{#each skills as |skill|}}
    <div class="skill-item card" data-item-id="{{skill.id}}">
      <div class="skill-main" data-action="rollSkill" data-item-id="{{skill.id}}">
        <span class="skill-name">{{skill.name}}</span>
        <span class="skill-attr">({{localize (lookup @root.config.attributes skill.system.attribute)}})</span>
      </div>
      <div class="skill-value">
        {{#if @root.isStepDice}}
            <span class="step-label">{{lookup @root.stepLabel skill.system.value}}</span>
            <input type="number" name="item.system.value" value="{{skill.system.value}}" data-action="updateItem" data-item-id="{{skill.id}}" data-dtype="Number">
        {{else}}
            <input type="number" name="item.system.value" value="{{skill.system.value}}" data-action="updateItem" data-item-id="{{skill.id}}" data-dtype="Number">
        {{/if}}
      </div>
      <div class="skill-actions">
        <button type="button" data-action="editItem" data-item-id="{{skill.id}}"><i class="fas fa-edit"></i></button>
        <button type="button" data-action="deleteItem" data-item-id="{{skill.id}}"><i class="fas fa-trash"></i></button>
      </div>
    </div>
    {{/each}}
  </div>
</div>

<div class="specialties-section">
  <div class="section-header">
    <h3>Especialidades</h3>
    <button type="button" data-action="createItem" data-type="specialty"><i class="fas fa-plus"></i></button>
  </div>
  <div class="specialty-list">
    {{#each specialties as |spec|}}
    <div class="specialty-item card" data-item-id="{{spec.id}}">
      <div class="specialty-header">
        <strong>{{spec.name}}</strong>
        <div class="item-actions">
          <button type="button" data-action="editItem" data-item-id="{{spec.id}}"><i class="fas fa-edit"></i></button>
          <button type="button" data-action="deleteItem" data-item-id="{{spec.id}}"><i class="fas fa-trash"></i></button>
        </div>
      </div>
      <div class="specialty-desc">{{{spec.system.description}}}</div>
    </div>
    {{/each}}
  </div>
</div>

